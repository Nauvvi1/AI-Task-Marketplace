generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  Draft
  AwaitingPayment
  PaymentPending
  Paid
  InProgress
  Completed
  Failed
  Refunded
  Canceled
}

enum PaymentStatus {
  Created
  AwaitingWallet
  PendingConfirmation
  Confirmed
  Expired
  Failed
  Refunded
}

enum JobStatus {
  Queued
  Running
  Completed
  Failed
}

model User {
  id                 String          @id @default(cuid())
  telegramId         String          @unique
  username           String?
  firstName          String?
  languageCode       String?
  walletAddress      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  lastSeenAt         DateTime?
  currentDraftOrderId String?
  orders             Order[]
  favorites          Favorite[]
}

model Service {
  id                  String   @id @default(cuid())
  code                String   @unique
  title               String
  description         String
  shortDescription    String
  priceTon            Decimal  @db.Decimal(10, 4)
  etaSeconds          Int
  promptTemplateVersion String @default("v1")
  inputSchemaJson     Json
  outputSchemaJson    Json
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  orders              Order[]
}

model Order {
  id               String        @id @default(cuid())
  publicOrderNo    String        @unique
  userId           String
  serviceId        String
  status           OrderStatus   @default(Draft)
  inputJson        Json?
  outputJson       Json?
  summaryJson      Json?
  priceTon         Decimal       @db.Decimal(10, 4)
  regenerateUsed   Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  paidAt           DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  canceledAt       DateTime?
  user             User          @relation(fields: [userId], references: [id])
  service          Service       @relation(fields: [serviceId], references: [id])
  paymentIntents   PaymentIntent[]
  generationJobs   GenerationJob[]
  orderMessages    OrderMessage[]
  favorites        Favorite[]
}

model PaymentIntent {
  id                String        @id @default(cuid())
  orderId           String
  amountTon         Decimal       @db.Decimal(10, 4)
  destinationAddress String
  paymentComment    String
  tonConnectPayload Json?
  status            PaymentStatus @default(Created)
  txHash            String?
  createdAt         DateTime      @default(now())
  confirmedAt       DateTime?
  expiredAt         DateTime?
  order             Order         @relation(fields: [orderId], references: [id])
}

model GenerationJob {
  id            String    @id @default(cuid())
  orderId       String
  status        JobStatus @default(Queued)
  attempts      Int       @default(0)
  modelName     String?
  promptVersion String?
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  order         Order     @relation(fields: [orderId], references: [id])
}

model OrderMessage {
  id                String   @id @default(cuid())
  orderId           String
  telegramChatId    String
  telegramMessageId String
  type              String
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  orderId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])

  @@unique([userId, orderId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  metaJson   Json?
  createdAt  DateTime @default(now())
}
