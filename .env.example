# Shared
NODE_ENV=development
APP_NAME=Nauvvi
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
BOT_BASE_URL=http://localhost:3002

# Public URLs
# WEB_URL and VITE_WEB_BASE_URL must point to the WEB ngrok tunnel (port 5173)
# VITE_API_BASE_URL must point to the API ngrok tunnel (port 3001)
WEB_URL=https://your-web-ngrok.ngrok-free.app
VITE_WEB_BASE_URL=https://your-web-ngrok.ngrok-free.app
VITE_API_BASE_URL=https://your-api-ngrok.ngrok-free.app

# Database / Queue
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ton-ai-nauvvi1
REDIS_URL=redis://localhost:6380

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_SUPPORT_URL=https://t.me/your_support_username
TELEGRAM_BOT_USERNAME=your_bot_username

# TON / Mini App
TON_RECEIVER_ADDRESS=your_ton_receiver_address
TON_NETWORK=testnet

# Payment mode
TON_PAYMENT_MODE=onchain
VITE_TON_PAYMENT_MODE=onchain

# Demo admin
ADMIN_SECRET=change_me